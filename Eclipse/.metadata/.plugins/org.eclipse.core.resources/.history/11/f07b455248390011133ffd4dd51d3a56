#include <stdio.h>
#include <unistd.h> // For usleep()
#define TASK_STACKSIZE       2048
#define VGA_TASK_PRIORITY    1

volatile int * ADDR_EXPORT = (int *) 0x04041010;
volatile int * PIXEL_EXPORT = (int *) 0x04041030;
volatile int * WREN_EXPORT = (int *) 0x04041000;
void write_pixel(unsigned int addr, unsigned char color);
void draw_color_stripes();
void draw_vertical_stripes();
void VGATask(void* pdata);
int main();

OS_STK VGA_Task_Stack[TASK_STACKSIZE];

void write_pixel(unsigned int addr, unsigned char color){

	*ADDR_EXPORT = addr;
	*PIXEL_EXPORT = color & 0xF;
	*WREN_EXPORT = 1;
	*WREN_EXPORT = 0;

}


void draw_color_stripes(){

	for (int y = 0; y < 240; y++){
		for (int x = 0; x < 320; x++){
			unsigned int addr = y * 320 + x;
			unsigned char color = x /20;
			write_pixel(addr, color);


		}
	}

}


void draw_vertical_stripes(){

	for (int y = 0; y < 240; y++){


		unsigned char color = y/15;
		for (int x = 0; x < 320; x++){

			unsigned int addr = y * 320 + x;
			write_pixel(addr, color);
		}

		}
}

void VGATask(void* pdata){

	while (1){

	// Your polling logic
			draw_color_stripes();
			printf("Horizontal stripes drawn.\n");
			usleep(1000000); // Wait 1 second (1,000,000 microseconds)

			draw_vertical_stripes();
			printf("Vertical stripes drawn.\n");
			usleep(1000000);
		}

int main() {
	printf("Starting Milestone 1 System...\n");

	OSInit();
	OSTaskCreateExt(VGATask,
	                    NULL,
	                    (void *)&VGA_Task_Stack[TASK_STACKSIZE-1],
	                    VGA_TASK_PRIORITY,
	                    VGA_TASK_PRIORITY,
	                    VGA_Task_Stack,
	                    TASK_STACKSIZE,
	                    NULL,
	                    0);

	// 3. Start the OS
	// This function never returns; it hands control to your VGATask
	OSStart();

	return 0;
}
