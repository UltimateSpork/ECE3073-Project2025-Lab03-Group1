


#include <stdio.h>
#include "includes.h" // Required for OSStart, OSInit, etc. [cite: 59]

#define VGA_TASK_PRIORITY  2
#define VGA_STACKSIZE      2048
OS_STK vga_stk[VGA_STACKSIZE];

void write_pixel(unsigned int addr, unsigned char color) {
    *ADDR_EXPORT = addr;
    *PIXEL_EXPORT = color & 0xF; // VGA only occupies 4 bits
    *WREN_EXPORT = 1;
    *WREN_EXPORT = 0;
}

// ... insert draw_color_stripes() and draw_vertical_stripes() here ...

void VGATask(void* pdata) {
    while (1) {
        draw_color_stripes();
        printf("Should output horizontal stripes\n"); [cite: 446]
        OSTimeDlyHMSM(0, 0, 1, 0); // 1 second delay

        draw_vertical_stripes();
        printf("Should output vertical stripes\n"); [cite: 446]
        OSTimeDlyHMSM(0, 0, 1, 0);
    }
}

int main(void) {
    printf("VGA Milestone 1 Starting...\n");
    OSInit();

    OSTaskCreateExt(VGATask,
                    NULL,
                    (void *)&vga_stk[VGA_STACKSIZE - 1],
                    VGA_TASK_PRIORITY,
                    VGA_TASK_PRIORITY,
                    vga_stk,
                    VGA_STACKSIZE,
                    NULL,
                    0);

    OSStart(); // Hands control to the VGATask [cite: 137]
    return 0;
}
