#include <stdio.h>

volatile int * LED_ptr = (int *) 0x000210b0;
/* Ideally you would use on address and both keys for the mask
but it wasn't working for some reason */
volatile int * key0 = (int *) 0x00021080;
volatile int * key1 = (int *) 0x00021090;

int main() {
    int button_pressed_previously0 = 1;
    int button_pressed_previously1 = 1;
    int bogus = 0;
    //printf("Press Key0/1\n");
    while (1) {
        int key0_val = *key0 & 0x1;
        int key1_val = *key1 & 0x1;

        // Detect Falling Edge (Press)
        if (key0_val == 0 && button_pressed_previously0 == 1) {
            *LED_ptr ^= 0x1; // Bitwise toggle
        }

        if (key1_val == 0 && button_pressed_previously1 == 1) {
            *LED_ptr ^= 0x2; // Toggle second LED bit
        }

        button_pressed_previously0 = key0_val;
        button_pressed_previously1 = key1_val;

        // Force the compiler to actually run this delay
        for (volatile int i = 0; i < 50000; i++);
    }

    return 0;
}
