#include <stdio.h>
#include "system.h"
#include "altera_avalon_pio_regs.h" // Standard HAL PIO functions
#include "unistd.h"                 // For usleep()
#include <io.h>
// Define your PIO bases from system.h
#define ADDR_BASE  0x04041050
#define PIXEL_BASE 0x04041070
#define WREN_BASE  0x04042000

void write_pixel(unsigned int addr, unsigned char color) {
	IOWR_ALTERA_AVALON_PIO_DATA(PIO_4_BASE, 0x00);
    IOWR_ALTERA_AVALON_PIO_DATA(ADDR_BASE, addr);
    IOWR_ALTERA_AVALON_PIO_DATA(PIXEL_BASE, color & 0xF);
    IOWR_ALTERA_AVALON_PIO_DATA(WREN_BASE, 1);
    IOWR_ALTERA_AVALON_PIO_DATA(WREN_BASE, 0);
}


int main() {
	printf("Starting HAL VGA Program...\n");

// TEST 1: Only the Address PIO
	IOWR_ALTERA_AVALON_PIO_DATA(ADDR_BASE, 0xFFFF);
	usleep(2000000); // Wait 2 seconds

	// TEST 2: Only the Pixel PIO
	IOWR_ALTERA_AVALON_PIO_DATA(PIO_10_BASE, 0xA);
	usleep(2000000);

	// TEST 3: Only the Write Enable
	IOWR_ALTERA_AVALON_PIO_DATA(PIO_13_BASE, 1);
	usleep(2000000);
    return 0;
}
